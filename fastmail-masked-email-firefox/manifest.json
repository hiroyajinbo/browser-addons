{
  "manifest_version": 3,
  "name": "Fastmail Masked Email",
  "version": "1.0.0",
  "description": "Unofficial Fastmail extension for creating and copying Masked Email addresses.",
  "homepage_url": "https://github.com/hiroyajinbo/browser-addons",
  "permissions": [
    "clipboardWrite",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://api.fastmail.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_title": "Fastmail Masked Email",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "assets/icon-48.png",
      "96": "assets/icon-96.png",
      "128": "assets/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "fastmail-masked-email@hiroyajinbo.github.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "authenticationInfo",
          "personallyIdentifyingInfo",
          "websiteActivity"
        ]
      }
    }
  },
  "icons": {
    "48": "assets/icon-48.png",
    "96": "assets/icon-96.png",
    "128": "assets/icon-128.png"
  }
}
