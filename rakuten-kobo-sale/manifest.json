{
  "manifest_version": 3,
  "name": "Rakuten Kobo Sale Exporter",
  "version": "1.0.0",
  "description": "楽天Koboセールページの「もっと見る」を展開し、書籍タイトル・価格・商品URLをCSVで保存します。",
  "content_scripts": [
    {
      "matches": [
        "https://books.rakuten.co.jp/event/e-book/*",
        "https://books.rakuten.co.jp/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "css": [
        "src/content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Kobo Sale Exporter",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "48": "assets/icon-48.png",
      "96": "assets/icon-96.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "48": "assets/icon-48.png",
    "96": "assets/icon-96.png",
    "128": "assets/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "rakuten-kobo-sale-exporter-local@example.com",
      "strict_min_version": "109.0"
    }
  }
}
