{
  "manifest_version": 3,
  "name": "Fastmail Checker",
  "version": "1.0.1",
  "description": "Unofficial Fastmail unread checker with per-folder notifications, filters, and mark-as-read support.",
  "homepage_url": "https://github.com/hiroyajinbo/browser-addons",
  "permissions": [
    "alarms",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://api.fastmail.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_title": "Fastmail Checker",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon-48.png",
      "96": "icon-96.png",
      "128": "icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "fastmail-checker@hiroyajinbo.github.io",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "authenticationInfo",
          "personalCommunications"
        ]
      }
    }
  },
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png"
  }
}
