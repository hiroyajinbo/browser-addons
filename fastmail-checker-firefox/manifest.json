{
  "manifest_version": 3,
  "name": "Fastmail Checker",
  "version": "1.0.0",
  "description": "Unofficial Fastmail unread checker with per-folder notifications, filters, and mark-as-read support.",
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://api.fastmail.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Fastmail Checker",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon-48.png",
      "96": "icon-96.png",
      "128": "icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "fastmail-checker-local@example.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png"
  }
}
