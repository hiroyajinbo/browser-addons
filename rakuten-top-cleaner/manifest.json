{
  "manifest_version": 3,
  "name": "Rakuten Top Cleaner",
  "version": "1.0.0",
  "description": "楽天市場トップページを、自分のブラウザ上だけで見やすく整理します。",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.rakuten.co.jp/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.rakuten.co.jp/*"
      ],
      "js": [
        "src/shared/constants.js",
        "src/shared/storage.js",
        "src/content/content.js"
      ],
      "css": [
        "src/content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Rakuten Top Cleaner",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "48": "assets/icon-48.png",
      "96": "assets/icon-96.png"
    }
  },
  "options_ui": {
    "page": "src/popup/popup.html",
    "open_in_tab": false
  },
  "icons": {
    "48": "assets/icon-48.png",
    "96": "assets/icon-96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "rakuten-top-cleaner-local@example.com",
      "strict_min_version": "109.0"
    }
  }
}
